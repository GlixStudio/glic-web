{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "glic-web",
  "compatibility_date": "2025-04-03",
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "encoder.glix.studio",
      "custom_domain": true
    }
  ],
  "vars": {
    "NODE_ENV": "development"
  }
}
